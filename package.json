{
  "name": "habitio-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:migrate:prod": "node dist/scripts/migrate.js",
    "smoke:remote": "tsx src/scripts/smoke-remote.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "deploy:start": "npm run db:migrate:prod && npm start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "mysql2": "^3.11.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}
